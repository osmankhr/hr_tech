# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# Scraper cache
.yok_cache/

# Environment
.env

# web backend runtime data
web/backend/*.db
web/backend/uploaded_cvs/

# web frontend
web/frontend/node_modules/
web/frontend/dist/

# candidate_pool campaign runtime data (contains real candidate PII once run) —
# only intentional example configs (campaign.yaml, input/) should be committed
candidate_pool/campaigns/*/data/
candidate_pool/campaigns/*/output/
candidate_pool/campaigns/*/logs/

# candidate_pool local campaign folders to keep out of git
candidate_pool/campaigns/*

# allowlist: keep these campaign folders commit-able
!candidate_pool/campaigns/example_2026-06-09/
!candidate_pool/campaigns/example_2026-06-09/**

# candidate_pool local lockfile
candidate_pool/uv.lock

# OS
.DS_Store
